pipeline {
  agent any

  stages {
    
    stage('clone') {
      steps {
        git url: 'https://github.com/vvce23ise0094-hue/Jenkinsfile2.git',
          branch: 'main'
      }
    }

    stage('Run python') {
      steps {
        sh 'chmod +x python.py'
        sh './python.py'
      }
    }
  }
}
