pipeline {
  agent any

  stages {
    
    stage('Clone') {
      steps {
        git url: 'https://github.com/vvce23ise0094-hue/jenkinsfile2.git',
            branch: 'main'
      }
    }

    stage('Setup Python Environment') {
      steps {
        sh '''
          python3 -m venv venv
          . venv/bin/activate
          pip install --upgrade pip
          pip install -r requirements.txt
        '''
      }
    }

    stage('Run Script') {
      steps {
        sh '''
          . venv/bin/activate
          python3 script.py
        '''
      }
    }
  }

  post {
    always {
      cleanWs()
    }
  }
}
